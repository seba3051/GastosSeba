PORT=3001

# OBLIGATORIO en producción: secreto para firmar los tokens de sesión.
# Usá un valor largo y aleatorio. Si cambia, se cierran las sesiones abiertas.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Carpeta donde se guarda la base SQLite (en Docker: /app/data con volumen).
# DATA_DIR=./data

# El registro de usuarios está CERRADO por defecto: solo se permite crear una
# cuenta si la base todavía no tiene ninguna. Poné 'true' de forma temporal si
# necesitás dar de alta otro usuario.
# ALLOW_REGISTRATION=true
